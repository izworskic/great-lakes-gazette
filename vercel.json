{
  "crons": [
    {
      "path": "/api/cron",
      "schedule": "0 8 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/chris-izworski",
      "destination": "/api/gateway?route=chris-izworski"
    },
    {
      "source": "/feed.xml",
      "destination": "/api/gateway?route=sitemap&format=rss"
    },
    {
      "source": "/sitemap.xml",
      "destination": "/api/gateway?route=sitemap"
    },
    {
      "source": "/archive",
      "destination": "/api/gateway?route=archive"
    },
    {
      "source": "/api/issue/:date",
      "destination": "/api/issue/[date]"
    },
    {
      "source": "/issue/:date",
      "destination": "/api/issue-page/[date]"
    },
    {
      "source": "/api/archive",
      "destination": "/api/gateway?route=archive"
    },
    {
      "source": "/api/chris-izworski",
      "destination": "/api/gateway?route=chris-izworski"
    },
    {
      "source": "/api/generate",
      "destination": "/api/gateway?route=generate"
    },
    {
      "source": "/api/issues",
      "destination": "/api/gateway?route=issues"
    },
    {
      "source": "/api/latest",
      "destination": "/api/gateway?route=latest"
    },
    {
      "source": "/api/publish",
      "destination": "/api/gateway?route=publish"
    },
    {
      "source": "/api/scrape",
      "destination": "/api/gateway?route=scrape"
    },
    {
      "source": "/api/sitemap",
      "destination": "/api/gateway?route=sitemap"
    },
    {
      "source": "/api/weather",
      "destination": "/api/gateway?route=weather"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "(?<sub>.*)\\.vercel\\.app"
        }
      ],
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "(?<sub>.*)\\.vercel\\.app"
        }
      ],
      "destination": "https://gazette.chrisizworski.com/:path*",
      "permanent": true
    }
  ],
  "$schema": "https://openapi.vercel.sh/vercel.json"
}
